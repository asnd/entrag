# LiteLLM Configuration
# Default: remote APIs via litellm (port 4000)
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=sk-your-key-here
LITELLM_MODEL=gpt-4o

# Local Models (optional):
# Uncomment to use local embedding service (port 4001)
# LITELLM_BASE_URL=http://litellm-local:4001
# LITELLM_EMBEDDING_MODEL=local-embedding

# LanceDB
LANCEDB_PATH=./data/lancedb

# Scraper Configuration
# Authentication is DISABLED by default (public articles only).
# Set SCRAPER_USE_AUTH=true and provide credentials to access restricted articles.
# Note: Authenticated scraping may have legal implications — use at your own risk.
# NOTE: playwright-based auth requires: pip install -e ".[playwright]"
SCRAPER_USE_AUTH=false
BROADCOM_USERNAME=your-email@example.com
BROADCOM_PASSWORD=your-password
SCRAPER_DELAY_SECONDS=3.0
SCRAPER_MAX_ARTICLES=100
SCRAPER_OUTPUT_DIR=./data/raw

# Gradio
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860

# Reranker
# NOTE: Local reranker requires: pip install -e ".[local]"
# Without it, reranking is skipped (retrieval still works via vector similarity).
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=5

# Retrieval
RETRIEVAL_SIMILARITY_TOP_K=10
RETRIEVAL_HYBRID_ALPHA=0.7
